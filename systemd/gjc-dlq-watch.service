[Unit]
Description=gjc DLQ-bury watcher (out-of-band alert on clawhip silent notification loss)
Documentation=file:/home/cvps/.omc/plans/discord-unification-plan.md
After=clawhip.service

[Service]
Type=simple
User=cvps
Environment=HOME=/home/cvps
ExecStart=/home/cvps/.gjc-relay/dlq-watch.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
