# fleet.toml — single host-local config surface for the gjc fleet.
#
# Copy to ~/.config/gjc-fleet/fleet.toml and fill in YOUR values.
# UNTRACKED BY DESIGN: this file holds numeric Discord channel IDs — never
# commit it, never paste it into issues or docs. It holds NO tokens/secrets:
# those live in the files pointed at by [secrets] (referenced by NAME only).
#
# Reference: docs/45-fleet-config.md. Renderer: render/render.sh.

[operator]
github_owner  = "example-owner"       # human GitHub account owning the target repos
bot_login     = "example-owner-bot"   # bot GitHub account (the active `gh` login)
bot_git_name  = "example-owner-bot"
bot_git_email = "000000+example-owner-bot@users.noreply.github.com"

[paths]
# Host-derived — the renderer defaults every key from $HOME and bot_login.
# Uncomment only to override.
# home       = "/home/youruser"
# gh_root    = "/home/youruser/github/example-owner-bot/fleet"    # pipeline clone root
# fleet_repo = "/home/youruser/github/example-owner-bot/gjc-fleet" # this repo's checkout

[discord.channels]
# name → numeric channel ID. THE untracked layer (repo policy: no numeric IDs
# in git, ever). Names are referenced by [[repos]].channel and the renderer.
default       = "000000000000000001"  # clawhip [defaults] — agent narration (#gjc-events)
gjc-events    = "000000000000000001"
gjc-approvals = "000000000000000002"
gjc-lab       = "000000000000000003"  # throwaway canary channel
# one per fleet repo (per-repo monitor notices):
example-repo  = "000000000000000004"

[relay]
bind = "127.0.0.1:25295"
# Managed-traffic rate budget for the v2 work-item path. Presets:
#   low  = 2 tokens / 5s   (conservative)
#   medium = 3 tokens / 5s (balanced, default)
#   high = 4 tokens / 5s   (throughput)
# Or an explicit "<tokens>/<window>s", e.g. "3/5s" (tokens 1..=4, window >= 1s).
managed_rate = "medium"
# Optional extra channel NAMES to opt into the managed work-item path without adding
# a repo monitor. Useful for canary/lab surfaces such as gjc-lab. Repo channels should
# normally use per-[[repos]] workitem_surface instead.
# workitem_channels = ["gjc-lab"]

# Optional per-channel debounce pins for the v2 managed path. Channel NAME -> seconds;
# the renderer resolves each to RELAY_DEBOUNCE_SECS__<numeric-id>. Omit entirely (the
# default) to use the relay's global debounce for every channel.
# [relay.debounce]
# example-repo = 10

[brain]
model            = "example/model-id"
nanogpt_base_url = "https://nano-gpt.com/api/v1/chat/completions"

[review]
# Coding engine for the REVIEW lane's handler runs. DEFAULT "gjc": the handler runs
# through the fleet's coding engine, inheriting gjc's own configured backend/models
# (the same engine as the gjc issue-fix lane). "claude" is the legacy fallback
# (headless `claude -p`), which uses model_primary/model_fast below.
#
# A host MAY pin engine = "claude" until the cutover gate passes — >=3 handler runs
# across >=2 repos (incl. >=1 failing-CI case) with auto-rollback armed. That is a
# deploy-time decision, not a code change.
engine        = "gjc"
# Used ONLY when engine = "claude" (the legacy Claude Code path). Ignored for gjc,
# which inherits its own backend/model configuration. Kept for the fallback.
model_primary = "opus"
model_fast    = "sonnet"

[review.policy]
# One-review policy for automated-author PRs (renovate/dependabot). For a PR opened
# by one of these logins the review lane consumes EXACTLY ONE suggestion-carrying
# augmentcode[bot] review, then makes a bounded APPLY / DISMISS / ESCALATE decision on
# any later review (docs/40 review-policy state machine). Human- and bot-authored PRs
# are untouched by this lane.
#
# Empty-list sentinel: setting this to an explicit empty list —
#   automated_authors = []
# DISABLES the policy lane. It renders REVIEW_AUTOMATED_AUTHORS=- (a lone hyphen, never
# empty so the template guard is satisfied); the detector treats "-" as the empty author
# set and matches no login. OMITTING the key entirely keeps the renovate/dependabot
# defaults below.
automated_authors = ["renovate[bot]", "dependabot[bot]"]
# Hard ceiling on handler launches per PR (first consume + APPLY relaunches). Once the
# consumed-marker count reaches this, further APPLY decisions record only, never relaunch.
max_handler_runs  = 2
# Force-push resilience (Workstream D). Renovate/dependabot force-push their PR branches; a
# policy review or ci-fix commit the fleet already acted on can be rebased away. When the PR
# head diverges from the sha we last acted on, the detector RE-ARMS the handler (dedup per
# head lineage). This is the hard ceiling on such re-arms per PR — once reached, the PR
# escalates once toward a human instead of looping. Omit to keep the default below.
max_rearms        = 2
# Decision engine for the later-review verdict. "brain" = the no-tools NanoGPT verdict
# path (same model as issue-triage / merge-gate). Inconclusive verdicts fail toward a human.
decision_mode     = "brain"

[ci_fixer]
# Phase B-3 fix-until-green loop. A timer-driven poller (pipeline/review/ci-fixer.sh)
# that, for a CI-RED bot-authored PR, launches ONE bounded coding-engine run to fix CI,
# then gives up loudly toward a human when its caps are exhausted.
#
# DEFAULT OFF. Three independent kill switches must ALL allow a run: enabled = true
# here, no `~/.gjc-bot/ci-fixer.disable` marker file on the host, and DRY_RUN unset
# (DRY_RUN=1 logs intended actions and takes none). Leave enabled = false until the
# deploy-time termination proofs (docs/40 runbook) have been walked.
enabled           = false
# Hard caps (bound the loop). At most max_per_sha attempts against one HEAD sha (retrying
# an unchanged sha rarely helps), and at most max_per_pr attempts across a PR's lifetime.
# Hitting EITHER cap is terminal: the poller escalates once to a human and stops.
max_per_sha       = 2
max_per_pr        = 5
# Exponential backoff base, minutes. The minimum wait since the last attempt on a PR is
# backoff_base_mins * 2^(attempts_so_far) — with the default 10: 10 / 20 / 40 / 80 …
backoff_base_mins = 10

[pins]
# Upstream engines — never vendored; installed via their own channels.
clawhip    = "0.6.11"    # cargo install clawhip --version <pin> --locked
gajae_code = "0.9.0"     # bun add -g gajae-code@<pin>
hermes_ref = "7fde19a"   # git checkout <pin> of NousResearch/hermes-agent

[cadence]
# Defaults match the shipped unit templates; informational unless you also
# adjust systemd/ timers.
janitor_every  = "2min"
adapter_backup = "5min"
detector_every = "5min"
gate_every     = "10min"

[secrets]
# POINTERS ONLY — file paths + key names, never values.
# hermes_env:  GITHUB_TOKEN, NANOGPT_API_KEY, DISCORD_BOT_TOKEN, DISCORD_HOME_CHANNEL
# clawhip_env: CLAWHIP_GITHUB_TOKEN, CLAWHIP_DISCORD_BOT_TOKEN, CLAWHIP_DISCORD_API_BASE
hermes_env  = "~/.hermes/.env"
clawhip_env = "~/.clawhip/clawhip.env"

# One [[repos]] block per fleet target repo — drives the clawhip
# [[monitors.git.repos]] blocks and the pipeline's repo auto-discovery scope.
# channel is a NAME resolved via [discord.channels].
#
# workitem_surface (optional, default false): opt this repo's channel into the v2
# managed work-item path. While every repo leaves it false (or unset), the renderer
# emits an EMPTY RELAY_WORKITEM_CHANNELS and the managed path stays fully OFF.
[[repos]]
name    = "example-repo"
github  = "example-owner/example-repo"
channel = "example-repo"
# workitem_surface = false
