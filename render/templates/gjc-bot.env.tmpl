# gjc-bot pipeline env — rendered from fleet.toml by render/render.sh (mode 0600).
# Consumed via EnvironmentFile= by the pipeline units. Numeric Discord channel
# IDs live ONLY here and in fleet.toml — never in the repo.
ISSUE_NOTIFY_CHANNEL={{CH_GJC_EVENTS}}
MERGE_GATE_CHANNEL={{CH_GJC_APPROVALS}}
REVIEW_NOTIFY_CHANNEL={{CH_GJC_EVENTS}}
# Coding engine for the REVIEW lane's handler run: "gjc" (default; inherits gjc's
# backend/models) or "claude" (legacy headless). From [review].engine in fleet.toml.
REVIEW_ENGINE={{REVIEW_ENGINE}}
# One-review policy for automated-author PRs (renovate/dependabot). From
# [review.policy] in fleet.toml. AUTHORS is space-joined; the detector routes a PR
# whose author login is in this set through the policy lane (exactly-one consume +
# bounded APPLY/DISMISS/ESCALATE). No numeric IDs — safe in the tracked template.
REVIEW_AUTOMATED_AUTHORS={{REVIEW_AUTOMATED_AUTHORS}}
REVIEW_POLICY_MAX_HANDLER_RUNS={{REVIEW_POLICY_MAX_HANDLER_RUNS}}
# Force-push resilience (Workstream D): hard ceiling on policy re-arms per PR (dedup per head
# lineage). When reached, the detector escalates once toward a human instead of looping.
REVIEW_POLICY_MAX_REARMS={{REVIEW_POLICY_MAX_REARMS}}
REVIEW_POLICY_DECISION_MODE={{REVIEW_POLICY_DECISION_MODE}}
# CI fixer (B-3 fix-until-green loop). From [ci_fixer] in fleet.toml. All non-numeric-ID
# knobs, so they ride the tracked template. CI_FIXER_ENABLED is the primary kill switch
# (0 = OFF, the default); the host marker ~/.gjc-bot/ci-fixer.disable and DRY_RUN are the
# other two. Caps + backoff bound the loop; the poller escalates once when a cap is hit.
CI_FIXER_ENABLED={{CI_FIXER_ENABLED}}
CI_FIXER_MAX_PER_SHA={{CI_FIXER_MAX_PER_SHA}}
CI_FIXER_MAX_PER_PR={{CI_FIXER_MAX_PER_PR}}
CI_FIXER_BACKOFF_BASE_MINS={{CI_FIXER_BACKOFF_BASE_MINS}}
# CI-fix lane author scope (E). Space-joined; "-" means the empty set (lane matches no one).
CI_FIXER_AUTHORS={{CI_FIXER_AUTHORS}}
# [merge] bot-side automerge lane (F). DEFAULT OFF (AUTOMERGE_ENABLED=0). Other kill switches:
# ~/.gjc-bot/automerge.disable marker + DRY_RUN. Owns renovate/dependabot PR merges via
# `gh pr merge --match-head-commit` (feature-probed, fail-closed); merge-gate stays advisory
# for bot-authored PRs. AUTHORS uses the "-"=empty sentinel like the review lists.
AUTOMERGE_ENABLED={{AUTOMERGE_ENABLED}}
AUTOMERGE_AUTHORS={{AUTOMERGE_AUTHORS}}
AUTOMERGE_METHOD={{AUTOMERGE_METHOD}}
AUTOMERGE_MIN_HEAD_AGE_MINS={{AUTOMERGE_MIN_HEAD_AGE_MINS}}
AUTOMERGE_REVIEW_WAIT_MINS={{AUTOMERGE_REVIEW_WAIT_MINS}}
AUTOMERGE_MAX_ATTEMPTS={{AUTOMERGE_MAX_ATTEMPTS}}
AUTOMERGE_MAX_PER_POLL={{AUTOMERGE_MAX_PER_POLL}}
# review.backlog liveness signal (K7): alert when the oldest unhandled PR exceeds this many minutes.
REVIEW_BACKLOG_ALERT_MINS={{REVIEW_BACKLOG_ALERT_MINS}}
# [janitor] coordinator tmux reaper (I). DEFAULT OFF; reaps completed/stale gjc-coordinator-*
# sessions past the grace window. Grace is in SECONDS (rendered from tmux_grace_mins).
JANITOR_TMUX_REAP_ENABLED={{JANITOR_TMUX_REAP_ENABLED}}
JANITOR_TMUX_GRACE_SECONDS={{JANITOR_TMUX_GRACE_SECONDS}}
# [updates] nightly fleet tool-update lane (G). DEFAULT OFF; quiesces engines, then updates the
# toolchain + hermes and re-asserts fleet pins. QUIESCE_TIMEOUT_MINS caps the lock wait.
TOOL_UPDATE_ENABLED={{TOOL_UPDATE_ENABLED}}
QUIESCE_TIMEOUT_MINS={{QUIESCE_TIMEOUT_MINS}}
